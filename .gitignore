# STM32 Keil MDK项目 .gitignore 文件
# 用于忽略Keil编译生成的临时文件和构建产物

# ===========================================
# 编译中间文件
# ===========================================
*.o       
*.d       
*.obj     
*.dep     
*.crf     
*.lst     
*.map     
*.lnp     

# ===========================================
# Keil IDE临时文件
# ===========================================
*.iex     
*.htm     
*.bak     
*.tmp     
*.rpt     
*.plg     
*.ddk     
*.edk     
*.mpf     
*.mpj     
*.omf     
*.__i     
*.tra     

# ===========================================
# 调试和编程文件
# ===========================================
JLinkLog.txt          
*.dbgconf             
DebugConfig/          

# ===========================================
# Keil项目文件（用户设置）
# ===========================================
*.uvoptx              
*.uvguix.*             

# ===========================================
# 其他工具生成文件
# ===========================================
.mxproject              

# ===========================================
# 构建输出文件
# ===========================================
*.axf                 
*.bin                 
*.hex           

# ===========================================
# 设置工作区文件
# ===========================================
*.code-workspace      

# ===========================================
# 自动生成目录
# ===========================================       
RTE/     
build/
.eide/
.vscode/
.pack/
.cmsis/

# ===========================================
# 资料目录
# ===========================================
FreeRTOS-LTS/

# ===========================================
# 需要保留的重要文件
# ===========================================
!*.uvprojx              
!*.h                  
!*.c                  
!*.ioc                
!*.sct                
